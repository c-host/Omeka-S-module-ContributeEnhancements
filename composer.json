{
    "name": "c-host/omeka-s-module-contribute-enhancements",
    "type": "omeka-s-module",
    "description": "Companion module for Omeka S Contribute: patch workflow, value removals, review UI, and archiving.",
    "license": "GPL-3.0-only",
    "autoload": {
        "psr-4": {
            "ContributeEnhancements\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ContributeEnhancementsTest\\": "test/"
        }
    },
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "scripts": {
        "test": "phpunit",
        "test:smoke": "php test/smoke.php"
    },
    "extra": {
        "installer-name": "ContributeEnhancements"
    }
}